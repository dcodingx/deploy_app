# ============================================================
# Voicebot Application — Environment Variables
# Copy this file to config/client.env and fill in real values
# ============================================================

# --- STT (Qwen3-ASR via vLLM) ---
# Used by Next.js frontend
ASR_API_URL=http://localhost:8000
# Used by pipecat bot
VLLM_ASR_BASE_URL=http://localhost:8000/v1
ASR_MODEL=Qwen/Qwen3-ASR-1.7B
# On NEC client with local model:
# ASR_MODEL=/opt/voicebot/models/STT_Q3_ASR_0_1

# --- LLM (vLLM OpenAI-compatible API) ---
# Used by Next.js frontend
LLM_API_URL=http://localhost:8001
# Used by pipecat bot
VLLM_LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=shisa-ai/shisa-v2-qwen2.5-7b

# --- TTS (Qwen3-TTS FastAPI server — voicebot-tts service) ---
# Used by Next.js frontend (/api/tts calls TTS_API_URL/tts_stream)
TTS_API_URL=http://localhost:8005
# Used by pipecat bot (Qwen3TTSService base_url)
VLLM_TTS_BASE_URL=http://localhost:8005

# --- Twilio (for pipecat voice bot) ---
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_AUTH_TOKEN

# --- Bot public URL (for Twilio TwiML callbacks) ---
# Must be the public hostname/IP of this server (no protocol, no trailing slash)
BASE_URL=ai-server.dcodingx.in

# --- TTS voice settings (pipecat bot) ---
TTS_LANGUAGE=English
TTS_SPEAKER=Ryan
